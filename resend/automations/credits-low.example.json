{
  "name": "LaunchPix - Credits low",
  "status": "disabled",
  "steps": [
    {
      "key": "trigger",
      "type": "trigger",
      "config": {
        "eventName": "credits.low"
      }
    },
    {
      "key": "send_credit_email",
      "type": "send_email",
      "config": {
        "template": {
          "id": "tpl_replace_with_credits_low_template_id",
          "variables": {
            "CREDITS": {
              "var": "credits"
            }
          }
        }
      }
    }
  ],
  "connections": [
    {
      "from": "trigger",
      "to": "send_credit_email",
      "type": "default"
    }
  ]
}
